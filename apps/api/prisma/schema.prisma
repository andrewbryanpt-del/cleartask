// Full data model — see docs/ARCHITECTURE.md for the design rationale.
// Every tenant-owned table carries organizationId; all queries are scoped
// to it via the auth plugin (single-database multi-tenancy).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum TaskPriority {
  URGENT
  HIGH
  NORMAL
  LOW
}

enum ProofType {
  PHOTO
  DOCUMENT
  SIGNATURE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum PermissionScope {
  ORG
  LOCATION
  DEPARTMENT
}

enum PushPlatform {
  WEB
  ANDROID
  IOS
}

// ---------- Tenancy & people ----------

model Organization {
  id        String   @id @default(uuid())
  name      String
  industry  String?
  logoKey   String?
  address   String?
  phone     String?
  website   String?
  // Set when the owner finishes the setup wizard; null routes owners to
  // onboarding after registration.
  onboardedAt              DateTime?
  // Notify the owner when a task is this many days past due and still
  // incomplete. Null disables escalation for this org.
  overdueEscalationDays    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations       Location[]
  departments     Department[]
  memberships     Membership[]
  roles           Role[]
  invitations     Invitation[]
  tasks           Task[]
  taskTemplates   TaskTemplate[]
  recurrenceRules RecurrenceRule[]
  attachments     Attachment[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  announcements   Announcement[]
}

model Location {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  address        String?
  timezone       String   @default("UTC")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departments     Department[]
  memberships     Membership[]     @relation("MembershipLocations")
  tasks           Task[]
  recurrenceRules RecurrenceRule[]

  @@index([organizationId])
}

model Department {
  id             String   @id @default(uuid())
  organizationId String
  locationId     String
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location        Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  memberships     Membership[]     @relation("MembershipDepartments")
  tasks           Task[]
  recurrenceRules RecurrenceRule[]

  @@index([organizationId])
  @@index([locationId])
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  avatarKey    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships   Membership[]
  refreshTokens RefreshToken[]
}

// A user's membership of one organization. Users can belong to several
// organizations (e.g. contractors); all org-scoped activity hangs off the
// membership, not the user.
model Membership {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  roleId         String?
  isOwner        Boolean  @default(false)
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull)
  departments  Department[] @relation("MembershipDepartments")
  locations    Location[]   @relation("MembershipLocations")

  assignments     TaskAssignment[]
  comments        TaskComment[]
  notifications   Notification[]
  attachmentViews     AttachmentView[]
  pushDevices         PushDevice[]
  announcementReads   AnnouncementRead[]
  announcementsPosted Announcement[]     @relation("AnnouncementAuthor")

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// A device registered for push delivery. `token` is the FCM registration
// token on Android/iOS, or the Web Push endpoint URL (with its crypto keys
// alongside) in the browser. Hangs off the membership so notifications stay
// org-scoped for users in several organizations.
model PushDevice {
  id            String       @id @default(uuid())
  membershipId  String
  platform      PushPlatform
  token         String       @unique
  webPushP256dh String?
  webPushAuth   String?
  createdAt     DateTime     @default(now())

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([membershipId])
}

// ---------- Custom roles & permissions ----------

model Role {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions  RolePermission[]
  memberships  Membership[]
  invitations  Invitation[]

  @@unique([organizationId, name])
}

// `permission` is a key from the fixed catalogue in
// packages/shared/src/permissions. `scope` narrows where it applies.
model RolePermission {
  id         String          @id @default(uuid())
  roleId     String
  permission String
  scope      PermissionScope @default(ORG)

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permission])
}

model Invitation {
  id                    String           @id @default(uuid())
  organizationId        String
  email                 String
  roleId                String?
  departmentIds         String[]         @default([])
  tokenHash             String           @unique
  status                InvitationStatus @default(PENDING)
  expiresAt             DateTime
  invitedByMembershipId String?
  createdAt             DateTime         @default(now())
  acceptedAt            DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([email])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------- Tasks ----------

model Task {
  id                     String    @id @default(uuid())
  organizationId         String
  locationId             String?
  departmentId           String?
  templateId             String?
  recurrenceRuleId       String?
  title                  String
  description            String?
  priority               TaskPriority @default(NORMAL)
  dueAt                  DateTime?
  // Minutes before dueAt to send escalating reminders, e.g. 7/3/1 days
  // before = [10080, 4320, 1440, 0]
  reminderOffsetsMinutes Int[]     @default([])
  createdByMembershipId  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location       Location?       @relation(fields: [locationId], references: [id], onDelete: SetNull)
  department     Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  template       TaskTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  recurrenceRule RecurrenceRule? @relation(fields: [recurrenceRuleId], references: [id], onDelete: SetNull)

  assignments TaskAssignment[]
  comments    TaskComment[]
  attachments Attachment[]

  @@index([organizationId, dueAt])
  @@index([organizationId, priority])
}

// One row per assigned person — assigning to a department fans out to one
// assignment per member, so status, proof, and audit are tracked per person.
model TaskAssignment {
  id                 String     @id @default(uuid())
  taskId             String
  membershipId       String
  status             TaskStatus @default(NOT_STARTED)
  sourceDepartmentId String?
  completedAt        DateTime?
  // Set by the overdue sweep so each assignment is only escalated once.
  overdueNotifiedAt    DateTime?
  // Set by the escalation sweep so the owner is only notified once per assignment.
  escalatedToOwnerAt   DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  task       Task                @relation(fields: [taskId], references: [id], onDelete: Cascade)
  membership Membership          @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  proofs     ProofOfCompletion[]

  @@unique([taskId, membershipId])
  @@index([membershipId, status])
}

model TaskTemplate {
  id                     String   @id @default(uuid())
  organizationId         String
  title                  String
  description            String?
  reminderOffsetsMinutes Int[]    @default([])
  createdByMembershipId  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks           Task[]
  attachments     Attachment[]
  recurrenceRules RecurrenceRule[]

  @@index([organizationId])
}

// iCalendar RRULE evaluated by a cron job that materializes the next
// concrete Task occurrence ahead of time. nextRunAt is the dueAt of the
// next occurrence still to be materialized. Assignees are stored on the
// rule so each materialized task runs the normal assignment fan-out.
model RecurrenceRule {
  id                    String    @id @default(uuid())
  organizationId        String
  templateId            String
  rrule                 String
  timezone              String    @default("UTC")
  active                Boolean   @default(true)
  nextRunAt             DateTime?
  locationId            String?
  departmentId          String?
  assigneeMembershipIds String[]  @default([])
  assigneeDepartmentIds String[]  @default([])
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     TaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  location     Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  tasks        Task[]

  @@index([active, nextRunAt])
}

// ---------- Files, comments, proof ----------

model Attachment {
  id                     String   @id @default(uuid())
  organizationId         String
  taskId                 String?
  templateId             String?
  uploadedByMembershipId String?
  fileName               String
  storageKey             String
  mimeType               String
  sizeBytes              Int
  createdAt              DateTime @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  task         Task?            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  template     TaskTemplate?    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  views        AttachmentView[]

  @@index([taskId])
}

// First-view tracking: "has this staff member opened the SOP/training doc?"
// acknowledgedAt is set when they tap "I have read and understood this".
model AttachmentView {
  id             String    @id @default(uuid())
  attachmentId   String
  membershipId   String
  viewedAt       DateTime  @default(now())
  acknowledgedAt DateTime?

  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([attachmentId, membershipId])
}

// ---------- Announcements ----------

model Announcement {
  id                    String   @id @default(uuid())
  organizationId        String
  title                 String
  body                  String
  createdByMembershipId String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author       Membership?        @relation("AnnouncementAuthor", fields: [createdByMembershipId], references: [id], onDelete: SetNull)
  reads        AnnouncementRead[]

  @@index([organizationId, createdAt])
}

model AnnouncementRead {
  id             String   @id @default(uuid())
  announcementId String
  membershipId   String
  readAt         DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  membership   Membership   @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([announcementId, membershipId])
}

model TaskComment {
  id           String   @id @default(uuid())
  taskId       String
  membershipId String
  body         String
  createdAt    DateTime @default(now())

  task       Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model ProofOfCompletion {
  id           String    @id @default(uuid())
  assignmentId String
  type         ProofType
  storageKey   String
  fileName     String?
  mimeType     String?
  createdAt    DateTime  @default(now())

  assignment TaskAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
}

// ---------- Notifications & audit ----------

model Notification {
  id             String    @id @default(uuid())
  organizationId String
  membershipId   String
  type           String
  title          String
  body           String?
  taskId         String?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  membership   Membership   @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([membershipId, readAt, createdAt])
}

// Append-only. actorMembershipId is intentionally a plain column (no FK)
// so audit rows survive member removal.
model AuditLog {
  id                String   @id @default(uuid())
  organizationId    String
  actorMembershipId String?
  action            String
  entityType        String
  entityId          String?
  detail            Json?
  createdAt         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}
