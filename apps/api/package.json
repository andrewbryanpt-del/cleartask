{
  "name": "@task-tracker/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --clean -d dist",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.0.0",
    "@prisma/client": "^6.0.0",
    "@task-tracker/shared": "*",
    "argon2": "^0.41.0",
    "dotenv": "^16.4.0",
    "exceljs": "^4.4.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "google-auth-library": "^10.7.0",
    "nodemailer": "^6.9.0",
    "pdfmake": "^0.2.10",
    "pg-boss": "^10.0.0",
    "rrule": "^2.8.1",
    "web-push": "^3.6.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^6.4.0",
    "@types/web-push": "^3.6.4",
    "prisma": "^6.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  }
}
