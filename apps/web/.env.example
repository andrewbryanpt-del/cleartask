# Optional local-dev fallback for Firebase push (production uses API runtime config).
# Primary config: set FIREBASE_WEB_* on the API service — see root .env.example.

# Required for Capacitor native builds — the Railway API host (not the static web app).
# Production web builds also load apps/web/.env.production with this value.
VITE_API_URL="https://api-production-332f.up.railway.app"

VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""
VITE_FIREBASE_VAPID_KEY=""
