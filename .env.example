# Copy to apps/api/.env and fill in real values. Never commit .env.

# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/task_tracker?schema=public"

# --- Auth ---
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET="change-me"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=30

# --- Server ---
PORT=3001
WEB_ORIGIN="http://localhost:5173"

# --- File storage ---
# "local" for development, "s3" for production (any S3-compatible provider:
# AWS S3, Cloudflare R2, Backblaze B2, MinIO)
STORAGE_DRIVER="local"
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# --- Email (transactional: invites, reminders, overdue alerts) ---
# Resend — https://resend.com
RESEND_API_KEY=""
EMAIL_FROM="ClearTask <noreply@cleartask.com.au>"

# --- Push notifications ---
# FCM delivery (web + native). Download service account JSON from Firebase
# Console → Project Settings → Service accounts.
FCM_SERVICE_ACCOUNT_PATH=""
FCM_SERVICE_ACCOUNT_JSON=""

# Firebase web config — served to browsers at runtime via GET /api/v1/push/web-config.
# Set these on the API service (not just the web service).
FIREBASE_WEB_API_KEY="AIzaSyAlBYP52cEB4P0EM6Q69Wqfl0UJgj_PTEo"
FIREBASE_WEB_AUTH_DOMAIN="cleartask-e76eb.firebaseapp.com"
FIREBASE_WEB_PROJECT_ID="cleartask-e76eb"
FIREBASE_WEB_STORAGE_BUCKET="cleartask-e76eb.firebasestorage.app"
FIREBASE_WEB_MESSAGING_SENDER_ID="764539990731"
FIREBASE_WEB_APP_ID="1:764539990731:web:572b9e618410ce271be14e"
FIREBASE_WEB_MEASUREMENT_ID="G-K44W0SDJ1V"
FIREBASE_WEB_VAPID_KEY="BFdRswe5PrKnhpCXA1sfE0a7S3QcRh-nA19JjJUcUovxzzqvByLQYf0Kh03T3mMnRnlb29LBdGWJPHKjkgaD40U"

# Legacy Web Push fallback (optional).
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:noreply@cleartask.com.au"
