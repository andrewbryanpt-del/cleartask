# Copy to apps/api/.env and fill in real values. Never commit .env.

# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/task_tracker?schema=public"

# --- Auth ---
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET="change-me"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=30

# --- Server ---
PORT=3001
WEB_ORIGIN="http://localhost:5173"

# --- File storage ---
# "local" for development, "s3" for production (any S3-compatible provider:
# AWS S3, Cloudflare R2, Backblaze B2, MinIO)
STORAGE_DRIVER="local"
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# --- Email (transactional: invites, reminders, overdue alerts) ---
# Resend — https://resend.com
RESEND_API_KEY=""
EMAIL_FROM="ClearTask <noreply@cleartask.com.au>"

# --- Push notifications (mobile) ---
# Web push VAPID keys + FCM for native push via Capacitor
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
FCM_SERVICE_ACCOUNT_JSON=""
